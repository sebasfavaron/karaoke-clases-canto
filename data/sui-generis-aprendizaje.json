    },
    {
      "time": 57.38,
      "text": "Quiero saber dónde debo ir"
    },
    {
      "time": 65.25,
      "text": "No quiero estar sin poder crecer"
    },
    {
      "time": 74.93,
      "text": "Aprendiendo las lecciones para ser"
    },
    {
