      "time": 6.59,
      "text": "Vuelve a despertar la lluvia en mí"
    },
    {
      "time": 9.44,
      "text": "Derramando toda su raíz"
    },
    {
      "time": 13.01,
      "text": "Sobre el papel"
    },
    {
      "time": 17.99,
      "text": "Vuelven a caer sobre la piel"
    },
    {
      "time": 20.95,
      "text": "Del que va esperando por nacer"
    },
    {
      "time": 24.62,
      "text": "Estás aquí"
    },
    {
      "time": 29.12,
      "text": "Mientras tanto, busco las palabras que me cubran esta herida"
    },
    {
      "time": 35.64,
      "text": "Que me alejen más de ti"
    },
    {
      "time": 41.08,
      "text": "Y la soledad me va creciendo con la niebla de este invierno"
    },
    {
      "time": 47.44,
      "text": "Que no puedo resistir"
    },
    {
      "time": 51.98,
      "text": "La noche sin ti"
    },
    {
      "time": 58.14,
      "text": "La mañana se levanta ya"
    },
    {
      "time": 61.34,
      "text": "No hay señales de que volverás"
    },
    {
      "time": 65.49,
      "text": "No estás aquí"
    },
    {
      "time": 70.19,
      "text": "Solamente quiero comprender"
    },
    {
      "time": 73.05,
      "text": "Que tu ausencia vive en mi pared"
    },
    {
      "time": 76.74,
      "text": "Y sin querer"
    },
    {
      "time": 81.61,
      "text": "¿Cómo detener este vacio que me crece desde adentro"
    },
    {
      "time": 87.93,
      "text": "Que no me deja seguir?"
    },
    {
      "time": 92.76,
      "text": "¿Cómo asimilar todos los huecos que aparecen en mi cama"
    },
    {
      "time": 99.35,
      "text": "Y se quedarán ahí?"
    },
    {
      "time": 103.65,
      "text": "Se apaga la luz (¿Cómo dice?)"
    },
    {
      "time": 110.7,
      "text": "(Y me siento solo con mi voz)"
    },
    {
      "time": 113.56,
      "text": "(No descubro cómo sucedió)"
    },
    {
      "time": 117.1,
      "text": "(Perder tu amor)"
    },
    {
      "time": 122.19,
      "text": "(Todo lo que nunca más veré)"
    },
    {
      "time": 126.96,
      "text": "(Cómo se me anuda el corazón)"
    },
    {
      "time": 128.98,
      "text": "(¿Cómo volver?)"
    },
    {
      "time": 133.57,
      "text": "(Si tuviera la oportunidad)"
    },
    {
      "time": 136.82,
      "text": "(En aquel minuto de parar)"
    },
    {
      "time": 140.43,
      "text": "(De no caer)"
    },
    {
      "time": 145.37,
      "text": "(Si quedaran rastros a seguir)"
